      "priority": 100
    },
    {
      "switch_rule_id": "switch_long_short",
      "enabled": true,
      "from_side": "long",
      "to_side": "short",
      "trigger_signal": "sig_short_entry",
      "close_quantity": "full_position",
      "next_entry_sequence": 1,
      "open_policy": "wait_entry_signal",
      "priority": 100
    },
    {
      "switch_rule_id": "switch_short_long",
      "enabled": true,
      "from_side": "short",
      "to_side": "long",
