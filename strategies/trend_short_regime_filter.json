{
  "name": "trend_short_regime_filter",
  "position_mode": "short_only",
  "basic": {
    "exchange": "binance_um_futures",
    "symbol": "BTCUSDT",
    "initial_capital": "1000",
    "leverage": "3",
    "compound_profit": false
  },
  "signals": [
    {
      "signal_id": "ema20",
      "signal_type": "single",
      "indicator_id": "ema",
      "version": "1",
      "interval": "1h",
      "params": {"period": 20},
      "trigger": "price_cross_below"
    },
    {
      "signal_id": "adx_strong",
      "signal_type": "single",
      "indicator_id": "adx",
      "version": "1",
      "interval": "1h",
      "params": {"period": 14},
      "trigger": "trend_strong"
    },
    {
      "signal_id": "atr14",
      "signal_type": "single",
      "indicator_id": "atr",
      "version": "1",
      "interval": "1h",
      "params": {"period": 14},
      "condition_operator": "none"
    },
    {
      "signal_id": "short_entry",
      "signal_type": "composite",
      "operator": "all",
      "conditions": [
        {"ref": "ema20", "ref_type": "user_signal"},
        {"ref": "adx_strong", "ref_type": "user_signal"}
      ]
    },
    {
      "signal_id": "short_pullback_exit",
      "signal_type": "position_indicator",
      "position_metric": "atr",
      "atr_signal": "atr14",
      "atr_operator": "price_gte",
      "atr_reference": "lowest_since_entry",
      "atr_multiplier": "1.0"
    },
    {
      "signal_id": "short_stop_loss",
      "signal_type": "position_indicator",
      "position_metric": "atr",
      "atr_signal": "atr14",
      "atr_operator": "price_lte",
      "atr_reference": "entry_price",
      "atr_multiplier": "-1.5"
    }
  ],
  "short": {
    "entry_rules": [
      {
        "entry_rule_id": "e_short",
        "enabled": true,
        "sequence": 1,
        "trigger_signal": "short_entry",
        "position_pct": "100",
        "priority": 100
      }
    ],
    "exit_rules": [
      {
        "exit_rule_id": "x_short_pullback",
        "enabled": true,
        "priority": 100,
        "quantity": "full_position",
        "exit_action": "take_profit",
        "trigger_signal": "short_pullback_exit"
      },
      {
        "exit_rule_id": "x_short_stop",
        "enabled": true,
        "priority": 101,
        "quantity": "full_position",
        "exit_action": "stop_loss",
        "trigger_signal": "short_stop_loss"
      }
    ]
  },
  "strategy_risk_rules": [
    {
      "risk_rule_id": "cooldown_after_exit",
      "enabled": true,
      "rule_type": "cooldown_bars",
      "value": 1,
      "after_event": "any_exit_fill",
      "applies_to": "entry_and_switch",
      "priority": 100
    },
    {
      "risk_rule_id": "max_exposure",
      "enabled": true,
      "rule_type": "max_exposure_percent",
      "threshold_pct": 200,
      "priority": 1
    }
  ]
}
