# Copy to .env and adjust for the machine.

# The repo ships a default binary at ./bin/backtest-live-runner.
# Override only when replacing it with a newer compatible build.
# BACKTEST_LIVE_RUNNER=/absolute/path/to/backtest-live-runner

# Local ClickHouse used by backtest-live-runner.
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=market
CLICKHOUSE_USER=quant
CLICKHOUSE_PASSWORD=quant

# Readonly market data API used to prepare only the symbol/window you need.
DATA_API_URL=https://data.becole.com

# Default market for examples.
BACKTEST_EXCHANGE=binance_um_futures
BACKTEST_SYMBOL=BTCUSDT
